<UserControl x:Class="ThinkGeo.UI.Wpf.HowDoI.BasicMapEvents"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:thinkGeoUi="clr-namespace:ThinkGeo.UI.Wpf;assembly=ThinkGeo.UI.Wpf"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <thinkGeoUi:MapView x:Name="Map" SizeChanged="Map_SizeChanged" AllowDrop="True" Grid.Column="0" />

        <Border Grid.Column="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="100"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Basic Map Events:" Margin="4" FontSize="14" FontWeight="Bold"/>
                        <CheckBox FontSize="14" FontWeight="Bold" Foreground="White" 
                              IsChecked="{Binding ShowMapLogs, Mode=TwoWay}"
                              Margin="4" Content="Map Events"/>
                        <CheckBox FontSize="14" FontWeight="Bold" Foreground="White" 
                              IsChecked="{Binding ShowExtentOverlayLogs, Mode=TwoWay}"
                              Margin="4" Content="ExtentOverlay Events"/>
                        <CheckBox FontSize="14" FontWeight="Bold" Foreground="White" 
                              IsChecked="{Binding ShowExtentOverlayMouseMoveLogs, Mode=TwoWay}"
                              Margin="20,4,4,4" Content="MouseMove Events"/>
                        <CheckBox FontSize="14" FontWeight="Bold" Foreground="White" 
                              IsChecked="{Binding ShowLayerOverlayLogs, Mode=TwoWay}"
                              Margin="4" Content="LayerOverlay Events"/>
                        <CheckBox FontSize="14" FontWeight="Bold" Foreground="White" 
                              IsChecked="{Binding ShowShapeFileLogs, Mode=TwoWay}"
                              Margin="4" Content="Feature Layer Events"/>
                    </StackPanel>

                    <Button Grid.Column="1" Content="Clear Logs" Width="80" Height="30"
                        VerticalAlignment="Bottom" HorizontalAlignment="Center" 
                        FontSize="14" Margin="5,5,5,5" Click="ClearLogs_Click"/>
                </Grid>

                <ListBox  Grid.Column="1" Grid.Row="1" Margin="5" x:Name="LogListBox"
                          ItemsSource="{Binding Path =FilteredLogMessages}"
                          VirtualizingStackPanel.IsVirtualizing="True"
                          VirtualizingStackPanel.VirtualizationMode="Recycling"
                          VerticalAlignment="Stretch"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0"/>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock TextWrapping="Wrap" HorizontalAlignment="Stretch" Margin="1">
                            <Run Text="{Binding Index, Mode=OneWay}"/>
                            <Run Text=". "/>
                            <Run Text="{Binding Category, Mode=OneWay}"/>
                            <Run Text=" -> "/>
                            <Run Text="{Binding Message, Mode=OneWay}"/>
                            </TextBlock>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="500" />
        </Grid.ColumnDefinitions>
    </Grid>

    <UserControl.Resources>
        <Style TargetType="Grid">
            <Setter Property="Background" Value="DimGray"></Setter>
            <Setter Property="Margin" Value="8,8,8,8"></Setter>
        </Style>
        <Style TargetType="Border">
            <Setter Property="BorderBrush" Value="Gray"></Setter>
            <Setter Property="BorderThickness" Value="1"></Setter>
        </Style>
        <Style TargetType="Separator">
            <Setter Property="Height" Value="12"></Setter>
            <Setter Property="Background" Value="Transparent"></Setter>
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="WhiteSmoke"></Setter>
            <Setter Property="FontSize" Value="14"></Setter>
            <Setter Property="FontWeight" Value="Bold"></Setter>
            <Setter Property="Margin" Value="0,0,0,4"></Setter>
        </Style>
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="WhiteSmoke"></Setter>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="4"></Setter>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Margin" Value="4"></Setter>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Margin" Value="4"></Setter>
        </Style>
    </UserControl.Resources>
</UserControl>
