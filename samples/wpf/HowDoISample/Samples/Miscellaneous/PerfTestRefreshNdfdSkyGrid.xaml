<UserControl x:Class="ThinkGeo.UI.Wpf.HowDoI.PerfTestRefreshNdfdSkyGrid"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:thinkGeoUi="clr-namespace:ThinkGeo.UI.Wpf;assembly=ThinkGeo.UI.Wpf"
             mc:Ignorable="d"
             d:DesignHeight="450"
             d:DesignWidth="800">
    <Grid>
        <thinkGeoUi:MapView Grid.Column="0" Grid.Row="0" x:Name="MapView" Loaded="MapView_Loaded"/>
        <Grid Grid.Column="1" Grid.Row="0">
            <Label Content="NDFD Sky Controls:" FontSize="16" FontWeight="Bold" Grid.Column="1" Grid.Row="0"/>
            <TextBlock x:Name="DataPathText"
                       Grid.Column="1"
                       Grid.Row="1"
                       Margin="0,10,0,0"
                       Foreground="WhiteSmoke"
                       TextWrapping="Wrap" />
            <TextBlock x:Name="FrameStatusText"
                       Grid.Column="1"
                       Grid.Row="2"
                       Margin="0,10,0,0"
                       Foreground="WhiteSmoke"
                       TextWrapping="Wrap" />
            <StackPanel Grid.Column="1" Grid.Row="3" Margin="0,10,0,0">
                <Label Content="Reprojection:"/>
                <ComboBox x:Name="ProjectionMode" SelectionChanged="ProjectionMode_SelectionChanged">
                    <ComboBoxItem Content="Lambert (Source)" Tag="Lambert" IsSelected="True"/>
                    <ComboBoxItem Content="Web Mercator (3857)" Tag="WebMercator"/>
                </ComboBox>
            </StackPanel>
            <StackPanel Grid.Column="1" Grid.Row="4" Margin="0,10,0,0">
                <Label Content="Resampling Mode:"/>
                <ComboBox x:Name="ResamplingMode" SelectionChanged="ResamplingMode_SelectionChanged">
                    <ComboBoxItem Content="Nearest Neighbor" Tag="NearestNeighbor" IsSelected="True"/>
                    <ComboBoxItem Content="Bilinear" Tag="Bilinear"/>
                    <ComboBoxItem Content="Trilinear" Tag="Trilinear"/>
                    <ComboBoxItem Content="Bicubic" Tag="Bicubic"/>
                    <ComboBoxItem Content="Auto" Tag="Auto"/>
                    <ComboBoxItem Content="Cartographic Auto" Tag="CartographicAuto"/>
                </ComboBox>
            </StackPanel>
            <StackPanel Grid.Column="1" Grid.Row="5" Margin="0,10,0,0">
                <Label Content="Color Style:"/>
                <RadioButton x:Name="StyleWeatherRainbow" Content="Weather Rainbow" IsChecked="True" Checked="StyleRadioButton_Checked"/>
                <RadioButton x:Name="StyleCloudGray"      Content="Cloud Gray"      Checked="StyleRadioButton_Checked"/>
                <RadioButton x:Name="StyleWarmTones"      Content="Warm Tones"      Checked="StyleRadioButton_Checked"/>
                <RadioButton x:Name="StyleCoolTones"      Content="Cool Tones"      Checked="StyleRadioButton_Checked"/>
                <RadioButton x:Name="StyleViridis"        Content="Viridis"         Checked="StyleRadioButton_Checked"/>
            </StackPanel>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="5" />
                <ColumnDefinition Width="240" />
                <ColumnDefinition Width="5" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
        </Grid>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
    </Grid>

    <UserControl.Resources>
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="WhiteSmoke"></Setter>
            <Setter Property="FontSize" Value="14"></Setter>
        </Style>
        <Style TargetType="Grid">
            <Setter Property="Background" Value="#20252D"></Setter>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Height" Value="22"></Setter>
            <Setter Property="Margin" Value="0,10,0,0"></Setter>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="20"></Setter>
        </Style>
        <Style TargetType="RadioButton">
            <Setter Property="Foreground" Value="WhiteSmoke"></Setter>
            <Setter Property="Margin" Value="0,2,0,0"></Setter>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#10151B"></Setter>
            <Setter Property="BorderBrush" Value="#38424F"></Setter>
            <Setter Property="Foreground" Value="WhiteSmoke"></Setter>
            <Setter Property="FontFamily" Value="Consolas"></Setter>
            <Setter Property="FontSize" Value="12"></Setter>
        </Style>
    </UserControl.Resources>
</UserControl>
