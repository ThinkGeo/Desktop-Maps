<UserControl x:Class="ThinkGeo.UI.Wpf.HowDoI.DragResizeAdornments"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:thinkGeoUi="clr-namespace:ThinkGeo.UI.Wpf;assembly=ThinkGeo.UI.Wpf"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <thinkGeoUi:MapView Grid.Column="0" Grid.Row="0" x:Name="MapView" SizeChanged="MapView_SizeChanged" />

        <Grid Grid.Column="1" Grid.Row="0">
            <Label Grid.Column="1" Grid.Row="0" Content="Drag/Resize Adornments" FontSize="16" FontWeight="Bold" />
            <Separator Grid.Column="1" Grid.Row="1" />

            <ScrollViewer Grid.Column="1" Grid.Row="2" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="0,0,4,0">
                    <GroupBox Header="Draggable">
                        <StackPanel>
                            <RadioButton x:Name="RdoDragYes" GroupName="DragMode" Content="Yes" IsChecked="True" Checked="DragMode_Checked" />
                            <RadioButton x:Name="RdoDragNo" GroupName="DragMode" Content="No" Checked="DragMode_Checked" />
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="Resizable" Margin="0,8,0,0">
                        <StackPanel>
                            <RadioButton x:Name="RdoResizeYes" GroupName="ResizeMode" Content="Yes" Checked="ResizeMode_Checked" />
                            <RadioButton x:Name="RdoResizeNo" GroupName="ResizeMode" Content="No" IsChecked="True" Checked="ResizeMode_Checked" />
                        </StackPanel>
                    </GroupBox>
                </StackPanel>
            </ScrollViewer>

            <!-- Controls Grid Layout -->
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="5" />
                <ColumnDefinition Width="260" />
                <ColumnDefinition Width="5" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
        </Grid>

        <!-- Grid Layout -->
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
    </Grid>

    <UserControl.Resources>
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="WhiteSmoke" />
        </Style>
        <Style TargetType="Grid">
            <Setter Property="Background" Value="DimGray" />
        </Style>
        <Style TargetType="RadioButton">
            <Setter Property="Foreground" Value="WhiteSmoke" />
            <Setter Property="Margin" Value="0,4,0,0" />
        </Style>
        <Style TargetType="GroupBox">
            <Setter Property="Foreground" Value="WhiteSmoke" />
        </Style>
        <Style TargetType="Separator">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Height" Value="8" />
        </Style>
    </UserControl.Resources>
</UserControl>
