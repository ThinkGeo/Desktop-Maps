<UserControl x:Class="ThinkGeo.UI.Wpf.HowDoI.Geocoding"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:thinkGeoUi="clr-namespace:ThinkGeo.UI.Wpf;assembly=ThinkGeo.UI.Wpf"
             xmlns:code="clr-namespace:ThinkGeo.Core;assembly=ThinkGeo.Core"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <thinkGeoUi:MapView  Grid.Column="0" Grid.Row="0" x:Name="Map" SizeChanged="Map_SizeChanged"></thinkGeoUi:MapView>
        <Image Grid.Column="0" x:Name="LoadingImage"  Height="64" Width="64" Visibility="Hidden" Source="..\..\Resources\loading.png" />
        <Grid Grid.Column="1" Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="160"/>
                <ColumnDefinition Width="5"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Label Grid.Column="1" Grid.Row="0" Grid.ColumnSpan="2">Search Text:</Label>
            <TextBox Grid.Column="1" Grid.ColumnSpan="2" Grid.Row="1" x:Name="TxtSearchString" Text="6101 Frisco Square Blvd, Frisco, TX 75034" />

            <Label Grid.Column="1" Grid.Row="2">Maximum Results:</Label>
            <TextBox Grid.Column="2" Grid.Row="2" x:Name="TxtMaxResults" Text="100" />

            <Label Grid.Column="1" Grid.Row="3">Country Codes:</Label>
            <TextBox Grid.Column="2" Grid.Row="3" x:Name="TxtCountryCodes" ToolTip="ISO 3166-1 alpha-2, comma-separated (e.g. us,ca)" />

            <Label Grid.Column="1" Grid.Row="4">Language:</Label>
            <TextBox Grid.Column="2" Grid.Row="4" x:Name="TxtLanguage" ToolTip="ISO 639-1, comma-separated (e.g. en,fr)" />

            <CheckBox Grid.Column="1" Grid.Row="5" Grid.ColumnSpan="2" x:Name="ChkAutocomplete"
                      Content="Autocomplete (prefix match)" />

            <CheckBox Grid.Column="1" Grid.Row="6" Grid.ColumnSpan="2" x:Name="ChkRestrictToExtent"
                      Content="Restrict to current map extent" IsChecked="True" />

            <Button Grid.Column="1" Grid.Row="7" Grid.ColumnSpan="2" Click="Search_Click">Search</Button>

            <TextBlock Grid.Column="1" Grid.Row="8" Grid.ColumnSpan="2" x:Name="TxtSearchResultsDescription" />

            <ListBox Grid.Column="1" Grid.Row="8" Grid.ColumnSpan="2" Name="LsbLocations"
                     SelectionChanged="lsbLocations_SelectionChanged"
                     ScrollViewer.CanContentScroll="True"
                     ScrollViewer.VerticalScrollBarVisibility="Visible"
                     Visibility="Hidden" Margin="0,30,0,0">
                <ListBox.ItemTemplate>
                    <DataTemplate DataType="{x:Type code:CloudGeocodingLocation}">
                        <Grid Width="Auto" Height="Auto">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="{Binding Path=LocationName}" TextWrapping="Wrap" FontWeight="Bold"/>
                            <TextBlock Grid.Row="1" Text="{Binding Path=LocationType, StringFormat=Type: {0}}"/>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>


        <!-- Grid Layout -->
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
    </Grid>
    <UserControl.Resources>
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="WhiteSmoke"></Setter>
            <Setter Property="FontSize" Value="14"></Setter>
        </Style>
        <Style TargetType="Grid">
            <Setter Property="Background" Value="DimGray"></Setter>
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"></Setter>
            <Setter Property="TextWrapping" Value="Wrap"></Setter>
            <Setter Property="Foreground" Value="WhiteSmoke"></Setter>
            <Setter Property="Margin" Value="0,5,0,0"></Setter>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Height" Value="20"></Setter>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Height" Value="22"></Setter>
            <Setter Property="Margin" Value="0,10,0,0"></Setter>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="20"></Setter>
        </Style>
        <Style TargetType="ListBox">
            <Setter Property="Height" Value="400"></Setter>
            <Setter Property="Margin" Value="0,10,0,0"></Setter>
        </Style>
        <Style TargetType="RadioButton">
            <Setter Property="Foreground" Value="WhiteSmoke"></Setter>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="WhiteSmoke"></Setter>
            <Setter Property="Margin" Value="0,5,0,0"></Setter>
        </Style>
    </UserControl.Resources>
</UserControl>