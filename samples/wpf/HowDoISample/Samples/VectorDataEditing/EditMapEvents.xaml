<UserControl x:Class="ThinkGeo.UI.Wpf.HowDoI.EditMapEvents"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:thinkGeoUi="clr-namespace:ThinkGeo.UI.Wpf;assembly=ThinkGeo.UI.Wpf"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <thinkGeoUi:MapView Grid.Column="0" Grid.Row="0" x:Name="MapView" Loaded="MapView_Loaded"/>

        <Border Grid.Column="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="2"/>
                    <ColumnDefinition x:Name="EventsColumn" Width="0"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <Button Content="Show Edit Events ▶" Click="ToggleEditEvents_Click"
                            FontSize="13" Margin="0,0,0,10" Background="SlateGray"
                            Foreground="WhiteSmoke" BorderBrush="#666"/>
                    <Label Grid.Column="1" Grid.Row="0" Content="Interactive Controls:" FontWeight="Bold" FontSize="16"/>

                    <RadioButton Grid.Column="1" Grid.Row="1" Content="Edit Shape" IsChecked="True" 
                                     Checked="EditShape_OnChecked" Unchecked="EditShape_OnUnchecked" />
                    <RadioButton Grid.Column="1" Grid.Row="2" Content="Draw Point" Click="DrawPoint_Click"/>
                    <RadioButton Grid.Column="1" Grid.Row="3" Content="Draw Line" Click="DrawLine_Click"/>
                    <RadioButton Grid.Column="1" Grid.Row="4" Content="Draw Polygon" Click="DrawPolygon_Click"/>
                    <RadioButton Grid.Column="1" Grid.Row="5" Content="Navigation Mode" 
                                     x:Name="NavModeRadio" Click="NavMode_Click"/>
                    <CheckBox Grid.Column="1" Grid.Row="6" x:Name="DeleteShape" 
                                  Content="Click on Shape to Delete " Margin="30,0,0,0"
                                  IsEnabled="{Binding IsChecked, ElementName=NavModeRadio}"/>

                    <Label Grid.Column="1" Grid.Row="7" Content="Instructions:" FontWeight="Bold" FontSize="16"/>
                    <TextBlock x:Name="Instructions" TextWrapping="Wrap" Grid.Column="1" Grid.Row="8"></TextBlock>

                    <Label Grid.Column="1" Grid.Row="9" Content="Measure:" FontWeight="Bold" FontSize="16"/>
                    <TextBlock x:Name="MeasureResult" Grid.Column="1" Grid.Row="10"></TextBlock>
                </StackPanel>

                <Border Grid.Column="1" Background="#555" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>

                <Grid x:Name="EditEventsPanel" Grid.Row="0" Grid.Column="2" Margin="10,5,0,0" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" VerticalAlignment="Top">

                        <TextBlock Text="Edit Map Events:" Margin="4" FontSize="14" FontWeight="Bold"/>
                        <CheckBox FontSize="14" FontWeight="Bold" Foreground="White" 
                                  IsChecked="{Binding ShowTrackOverlayLogs, Mode=TwoWay}"
                                  Margin="4" Content="TrackOverlay Events"/>
                        <CheckBox FontSize="14" FontWeight="Bold" Foreground="White" 
                                  IsChecked="{Binding ShowTrackOverlayMouseMoveLogs, Mode=TwoWay}"
                                  Margin="20,4,4,4" Content="MouseMove Events"/>
                        <CheckBox FontSize="14" FontWeight="Bold" Foreground="White" 
                                  IsChecked="{Binding ShowEditOverlayLogs, Mode=TwoWay}"
                                  Margin="4" Content="EditOverlay Events"/>
                        <CheckBox FontSize="14" FontWeight="Bold" Foreground="White" 
                                  IsChecked="{Binding ShowEditOverlayMouseMoveLogs, Mode=TwoWay}"
                                  Margin="20,4,4,4" Content="MouseMove Events"/>
                    </StackPanel>

                    <Button Grid.Row="1" Content="Clear Logs" Width="80" Height="30"
                            VerticalAlignment="Bottom" HorizontalAlignment="Right" 
                            FontSize="14" Margin="5,5,25,5" Click="ClearLogs_Click"/>
                </Grid>

                <ListBox  x:Name="LogListBox" Grid.Row="1" Grid.ColumnSpan="3" 
                          Margin="5" Visibility="Collapsed" 
                          ItemsSource="{Binding Path =FilteredLogMessages}"
                          VirtualizingStackPanel.IsVirtualizing="True"
                          VirtualizingStackPanel.VirtualizationMode="Recycling"
                          VerticalAlignment="Stretch"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                          Background="#F2F2F2" Foreground="#222222" BorderBrush="#CCCCCC">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0"/>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock TextWrapping="Wrap" HorizontalAlignment="Stretch" Margin="1">
                            <Run Text="{Binding Index, Mode=OneWay}"/>
                            <Run Text=". "/>
                            <Run Text="{Binding Category, Mode=OneWay}"/>
                            <Run Text=" -> "/>
                            <Run Text="{Binding Message, Mode=OneWay}"/>
                            </TextBlock>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition x:Name="RightPanelColumn" Width="300" />
        </Grid.ColumnDefinitions>
    </Grid>

    <UserControl.Resources>
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="WhiteSmoke"></Setter>
        </Style>
        <Style TargetType="Grid">
            <Setter Property="Background" Value="DimGray"></Setter>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Height" Value="20"></Setter>
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="WhiteSmoke"></Setter>
            <Setter Property="Margin" Value="4"></Setter>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Height" Value="22"></Setter>
            <Setter Property="Margin" Value="0,10,0,0"></Setter>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="20"></Setter>
        </Style>
        <Style TargetType="RadioButton">
            <Setter Property="Foreground" Value="WhiteSmoke"></Setter>
            <Setter Property="Margin" Value="8,0,0,0"></Setter>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="WhiteSmoke"></Setter>
        </Style>
    </UserControl.Resources>
</UserControl>