<UserControl x:Class="ThinkGeo.UI.Wpf.HowDoI.RestrictMapExtent"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:thinkGeoUi="clr-namespace:ThinkGeo.UI.Wpf;assembly=ThinkGeo.UI.Wpf"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">

    <Grid>
        <thinkGeoUi:MapView Grid.Column="0" Grid.Row="0" x:Name="MapView" SizeChanged="MapView_SizeChanged"/>

        <!-- Scale display -->
        <TextBlock Background="gray" VerticalAlignment="Bottom" HorizontalAlignment="Center"
                   Width="180" Height="30" FontSize="20" TextAlignment="Center" Margin="0,0,0,10"
                   Text="{Binding ElementName=MapView, Path=CurrentScale, StringFormat={}Scale: {0:N0}}"/>

        <!-- Controls -->
        <Grid Grid.Column="1" Grid.Row="0">
            <Label Grid.Row="0" Content="Restrictions:" FontSize="16" FontWeight="Bold"/>
            <StackPanel Grid.Row="1">
                <CheckBox x:Name="ChkRestrictExtent" Content="Enable RestrictExtent" IsChecked="True" Click="ChkRestriction_Click"/>
                <CheckBox x:Name="ChkMaximumScale" Content="Enable MaximumScale (1:500,000)" IsChecked="True" Click="ChkRestriction_Click"/>
                <CheckBox x:Name="ChkMinimumScale" Content="Enable MinimumScale (1:10,000)" IsChecked="True" Click="ChkRestriction_Click"/>
            </StackPanel>

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
        </Grid>

        <!-- Grid Layout -->
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" MinWidth="256"/>
        </Grid.ColumnDefinitions>
    </Grid>

    <!-- Styles -->
    <UserControl.Resources>
        <Style TargetType="Grid">
            <Setter Property="Background" Value="DimGray"/>
            <Setter Property="Margin" Value="8,8,8,8"/>
        </Style>
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="WhiteSmoke"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="WhiteSmoke"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="4"/>
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="WhiteSmoke"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
    </UserControl.Resources>
</UserControl>
