<UserControl x:Class="ThinkGeo.UI.Wpf.HowDoI.OverviewMap" 
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" 
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" 
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:thinkGeoUi="clr-namespace:ThinkGeo.UI.Wpf;assembly=ThinkGeo.UI.Wpf" 
             mc:Ignorable="d" d:DesignHeight="450" d:DesignWidth="800">

    <UserControl.Resources>
        <Style x:Key="ImageButtonNoHoverStyle" TargetType="Button">
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />

        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />

        </Grid.ColumnDefinitions>

        <thinkGeoUi:MapView x:Name="MapView" Grid.Row="0" Grid.Column="0" Grid.RowSpan="3" Grid.ColumnSpan="4" Loaded="MapView_Loaded" />

        <Button x:Name="CompassButton" 
                Style="{StaticResource ImageButtonNoHoverStyle}" 
                Grid.Row="0" Grid.Column="0" Grid.RowSpan="3" Grid.ColumnSpan="4" 
                Panel.ZIndex="10" Width="40" Height="40" Background="Transparent" 
                BorderThickness="0" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="10" 
                Click="CompassButton_Click" ToolTip="Reset north" RenderTransformOrigin="0.5,0.5">
            <Button.RenderTransform>
                <RotateTransform Angle="{Binding ElementName=MapView, Path=RotationAngle}" />
            </Button.RenderTransform>
            <Image Source="/Resources/icon_north_arrow.png" Stretch="Fill" />
        </Button>

        <Grid Grid.Row="0" Grid.Column="0" Grid.RowSpan="3" Grid.ColumnSpan="4" Panel.ZIndex="1" Margin="8" Width="220" Height="220" 
              HorizontalAlignment="Left" VerticalAlignment="Bottom">
            <Border BorderBrush="#FF333333" BorderThickness="5" CornerRadius="6" Background="#00FFFFFF" SnapsToDevicePixels="True" ClipToBounds="True">
                <Grid>
                    <thinkGeoUi:MapView x:Name="MiniMapView" Loaded="MiniMapView_Loaded" />

                    <Canvas x:Name="MiniHud" Background="Transparent">
                        <Path x:Name="ViewportBox" Stroke="Red" StrokeThickness="3" Fill="#00FFFFFF" />
                        <Path x:Name="CenterStar" Width="10" Height="10" Fill="Red" Stretch="Uniform" >
                            <Path.RenderTransform>
                                <TransformGroup>
                                    <RotateTransform x:Name="StarRotate" Angle="0" CenterX="5" CenterY="5" />
                                    <TranslateTransform x:Name="StarTranslate" X="0" Y="0" />
                                </TransformGroup>
                            </Path.RenderTransform>
                            <Path.Data>
                                <PathGeometry Figures="M 0,-10 L 2.94,-3.09 9.51,-3.09 4.28,1.18 6.80,8.09 0,4 -6.80,8.09 -4.28,1.18 -9.51,-3.09 -2.94,-3.09 Z" />
                            </Path.Data>
                        </Path>
                    </Canvas>
                    
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>