<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFrameworks>net8.0-windows;net48</TargetFrameworks>
    <UseWPF>true</UseWPF>
    <RootNamespace>ThinkGeo.UI.Wpf.HowDoI</RootNamespace>
    <AssemblyName>ThinkGeo.UI.Wpf.HowDoI</AssemblyName>
    <UserSecretsId>1d8a5313-9352-402d-84fd-6b51ca25705e</UserSecretsId>
    <StartupObject>
    </StartupObject>
<!-- x64 required by ThinkGeo.FileGeoDatabase (Esri.FileGDBAPI.dll is AMD64-only).
         Other ThinkGeo components support AnyCPU/x86. -->
    <PlatformTarget>x64</PlatformTarget>
  </PropertyGroup>

  <Target Name="RemoveDuplicateAnalyzers" BeforeTargets="CoreCompile">
    <!-- Work around github.com/dotnet/wpf/issues/6792 -->
    <ItemGroup>
      <FilteredAnalyzer Include="@(Analyzer-&gt;Distinct())" />
      <Analyzer Remove="@(Analyzer)" />
      <Analyzer Include="@(FilteredAnalyzer)" />
    </ItemGroup>
  </Target>

  <ItemGroup>
    <Compile Remove="HowDoI\**;SampleTemplate.xaml.cs" />
    <EmbeddedResource Remove="HowDoI\**" />
    <None Remove="HowDoI\**;.gitignore;HowDoI.csproj.DotSettings;HowDoI.sln.DotSettings;README.md;Screenshot.gif;Data\Jpg\m87_*.jpg;Resources\favicon.ico;Resources\logo.png;Resources\marker.png;Resources\empire_state_building.png;Resources\generic-logo.png;Resources\icon_globe_black.png;Resources\loading.png;Resources\vehicle_location.png;Resources\icon_north_arrow.png" />
    <Page Remove="HowDoI\**;SampleTemplate.xaml" />
  </ItemGroup>

  <ItemGroup>
    <Page Update="Samples\MapOfflineData\Vector\GenerateESRIGridFile.xaml">
      <XamlRuntime>$(DefaultXamlRuntime)</XamlRuntime>
    </Page>
    <Page Update="Samples\MapOfflineData\Raster\DisplayGdalFile.xaml">
