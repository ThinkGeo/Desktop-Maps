  <ItemGroup>
    <Resource Include="Resources\favicon.ico;Resources\logo.png;Resources\marker.png;Resources\empire_state_building.png;Resources\generic-logo.png;Resources\icon_globe_black.png;Resources\loading.png;Resources\vehicle_location.png;Resources\icon_north_arrow.png">
